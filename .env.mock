# Mock模式：不连后端，所有API走本地mock（开发+构建均可用）
NODE_ENV=production

VITE_DEV=false

# 关键：base_url 为空，让请求走 vite dev server → mock 拦截
VITE_BASE_URL=''

VITE_IIMAKE_CLIENT_ID=8639cc903277a8865f44da1dde5cbb65
VITE_IIMAKE_SSO_URL=https://umc-test.iimake.com/api/admin-api/system/oauth2/authorize

VITE_UPLOAD_TYPE=server
VITE_API_URL=/admin-api

VITE_DROP_DEBUGGER=false
VITE_DROP_CONSOLE=false
VITE_SOURCEMAP=false
VITE_BASE_PATH=/

# 关闭验证码
VITE_APP_CAPTCHA_ENABLE=false

# 关闭租户
VITE_APP_TENANT_ENABLE=false
